# ─── GymBook NXT — Variables de Entorno ─────────────────────
# Copia este archivo a .env y completa los valores

# ── Base de Datos (PostgreSQL) ───────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/gymbook_nxt?schema=public"

# ── NextAuth v5 ──────────────────────────────────────────────
# Genera con: openssl rand -base64 32
AUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"
# En Railway: https://your-app.up.railway.app

# ── Twilio WhatsApp ───────────────────────────────────────────
# Obtén en: https://console.twilio.com
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Sandbox: whatsapp:+14155238886  |  Producción: whatsapp:+34XXXXXXXXX
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="GymBook NXT"
NODE_ENV="development"
