// ============================================================
// GymBook NXT — Prisma Schema Unificado
// Fase I: Training + Nutrition + Credits + Progress + Calendar
// Roles: TRAINER | CLIENT (sin Admin — primer trainer = Initial Owner)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum Role {
  TRAINER
  CLIENT
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum FitnessGoal {
  LOSE_WEIGHT
  GAIN_MUSCLE
  IMPROVE_ENDURANCE
  IMPROVE_FLEXIBILITY
  GENERAL_FITNESS
  ATHLETIC_PERFORMANCE
  MAINTAIN
}

enum FitnessLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  ELITE
}

enum CreditPackageType {
  SINGLE     // 1x1
  FIVE       // 5x5
  TEN        // 10x10
  TWENTY     // 20x20
  CUSTOM
}

enum CreditStatus {
  ACTIVE
  USED
  EXPIRED
  REFUNDED
}

enum ProgramStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
  PRE_WORKOUT
  POST_WORKOUT
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  SYSTEM
}

// ─────────────────────────────────────────
// ORGANIZATION (White-label support)
// ─────────────────────────────────────────

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logoUrl     String?
  primaryColor String? @default("#3B82F6")
  accentColor  String? @default("#EAB308")
  website     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]

  @@map("organizations")
}

// ─────────────────────────────────────────
// USER (Trainer + Client unified)
// ─────────────────────────────────────────

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  emailVerified  DateTime?
  passwordHash   String?
  name           String
  avatarUrl      String?
  role           Role     @default(CLIENT)
  isInitialOwner Boolean  @default(false) // primer trainer = owner completo
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  // Perfil extendido
  trainerProfile TrainerProfile?
  clientProfile  ClientProfile?

  // Relaciones como trainer
  clientsAsTrainer Client[] @relation("TrainerClients")

  // Relaciones como cliente
  clientRecord     Client?  @relation("ClientUser")

  // Mensajería
  sentMessages     Message[] @relation("MessageSender")

  @@map("users")
}

// ─────────────────────────────────────────
// TRAINER PROFILE
// ─────────────────────────────────────────

model TrainerProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio          String?
  specialties  String[] // e.g. ["strength", "nutrition", "yoga"]
  certifications String[]
  yearsExp     Int?
  instagramUrl String?
  calendlyUrl  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  availability TrainerAvailability[]

  @@map("trainer_profiles")
}

// ─────────────────────────────────────────
// CLIENT PROFILE (Onboarding profundo)
// ─────────────────────────────────────────

model ClientProfile {
  id             String      @id @default(cuid())
  userId         String      @unique
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Datos físicos
  dateOfBirth    DateTime?
  gender         Gender?
  heightCm       Float?
  weightKg       Float?

  // Metas y nivel
  fitnessGoal    FitnessGoal?
  fitnessLevel   FitnessLevel?
  targetWeightKg Float?

  // Salud
  injuries       String[]
  medicalNotes   String?

  // Preferencias alimentarias
  dietaryRestrictions String[] // ["vegetarian", "gluten-free", ...]
  allergies      String[]

  // Onboarding completo?
  onboardingCompleted Boolean @default(false)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("client_profiles")
}

// ─────────────────────────────────────────
// CLIENT (Relación Trainer → Cliente)
// ─────────────────────────────────────────

model Client {
  id        String   @id @default(cuid())
  trainerId String
  trainer   User     @relation("TrainerClients", fields: [trainerId], references: [id])
  userId    String   @unique
  user      User     @relation("ClientUser", fields: [userId], references: [id])
  notes     String?
  isActive  Boolean  @default(true)
  joinedAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Credits
  userCredits  UserCredit[]

  // Training
  trainingPrograms TrainingProgram[]

  // Nutrition
  nutritionPlans   NutritionPlan[]

  // Progress
  progressLogs     ProgressLog[]

  // Mensajería
  conversations    Conversation[] @relation("ConversationClient")

  @@map("clients")
}

// ─────────────────────────────────────────
// CREDITS SYSTEM
// ─────────────────────────────────────────

model CreditPackage {
  id          String            @id @default(cuid())
  name        String            // "Pack 10 sesiones"
  type        CreditPackageType
  totalCredits Int
  price       Float
  currency    String            @default("EUR")
  validDays   Int?              // días de validez, null = sin límite
  isActive    Boolean           @default(true)
  description String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  userCredits UserCredit[]

  @@map("credit_packages")
}

model UserCredit {
  id              String        @id @default(cuid())
  clientId        String
  client          Client        @relation(fields: [clientId], references: [id])
  packageId       String
  package         CreditPackage @relation(fields: [packageId], references: [id])
  totalCredits    Int
  usedCredits     Int           @default(0)
  remainingCredits Int          // computed / maintained manually
  status          CreditStatus  @default(ACTIVE)
  purchasedAt     DateTime      @default(now())
  expiresAt       DateTime?
  updatedAt       DateTime      @updatedAt

  usageLogs CreditUsageLog[]

  @@map("user_credits")
}

model CreditUsageLog {
  id           String     @id @default(cuid())
  userCreditId String
  userCredit   UserCredit @relation(fields: [userCreditId], references: [id])
  usedAt       DateTime   @default(now())
  notes        String?
  sessionId    String?    // referencia a workout session si aplica

  @@map("credit_usage_logs")
}

// ─────────────────────────────────────────
// TRAINING (Programs + Workouts + Exercises)
// ─────────────────────────────────────────

model TrainingProgram {
  id          String        @id @default(cuid())
  clientId    String
  client      Client        @relation(fields: [clientId], references: [id])
  name        String
  description String?
  status      ProgramStatus @default(ACTIVE)
  startDate   DateTime?
  endDate     DateTime?
  durationWeeks Int?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  workouts    Workout[]

  @@map("training_programs")
}

model Workout {
  id          String          @id @default(cuid())
  programId   String
  program     TrainingProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  name        String          // "Día A - Upper Body"
  dayOfWeek   DayOfWeek?
  weekNumber  Int?
  orderIndex  Int             @default(0)
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  exercises   WorkoutExercise[]
  sessions    WorkoutSession[]

  @@map("workouts")
}

model Exercise {
  id           String   @id @default(cuid())
  name         String
  muscleGroups String[] // ["chest", "triceps"]
  equipment    String[] // ["barbell", "bench"]
  instructions String?
  videoUrl     String?
  imageUrl     String?
  createdAt    DateTime @default(now())

  workoutExercises WorkoutExercise[]

  @@map("exercises")
}

model WorkoutExercise {
  id          String   @id @default(cuid())
  workoutId   String
  workout     Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exerciseId  String
  exercise    Exercise @relation(fields: [exerciseId], references: [id])
  orderIndex  Int      @default(0)
  sets        Int?
  reps        String?  // "8-12" o "10" — flexible
  weightKg    Float?
  restSeconds Int?
  tempo       String?  // "3-1-2-0"
  rpe         Int?     // Rate of Perceived Exertion 1-10
  notes       String?

  logs        ExerciseLog[]

  @@map("workout_exercises")
}

model WorkoutSession {
  id          String   @id @default(cuid())
  workoutId   String
  workout     Workout  @relation(fields: [workoutId], references: [id])
  completedAt DateTime @default(now())
  durationMin Int?
  notes       String?
  rpe         Int?
  creditUsed  Boolean  @default(false)

  exerciseLogs ExerciseLog[]

  @@map("workout_sessions")
}

model ExerciseLog {
  id                String          @id @default(cuid())
  sessionId         String
  session           WorkoutSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  workoutExerciseId String
  workoutExercise   WorkoutExercise @relation(fields: [workoutExerciseId], references: [id])
  setNumber         Int
  repsCompleted     Int?
  weightKgUsed      Float?
  rpe               Int?
  notes             String?
  completedAt       DateTime        @default(now())

  @@map("exercise_logs")
}

// ─────────────────────────────────────────
// NUTRITION (unified with training)
// ─────────────────────────────────────────

model NutritionPlan {
  id          String        @id @default(cuid())
  clientId    String
  client      Client        @relation(fields: [clientId], references: [id])
  name        String
  description String?
  status      ProgramStatus @default(ACTIVE)
  caloriesTarget   Int?
  proteinGTarget   Float?
  carbsGTarget     Float?
  fatGTarget       Float?
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  weeklyPlans WeeklyMealPlan[]
  dailyIntakes DailyIntake[]

  @@map("nutrition_plans")
}

model WeeklyMealPlan {
  id             String        @id @default(cuid())
  nutritionPlanId String
  nutritionPlan  NutritionPlan @relation(fields: [nutritionPlanId], references: [id], onDelete: Cascade)
  weekNumber     Int
  name           String?       // "Semana 1 - Volumen"
  notes          String?
  createdAt      DateTime      @default(now())

  mealEntries    WeeklyMealEntry[]

  @@map("weekly_meal_plans")
}

model Recipe {
  id           String   @id @default(cuid())
  name         String
  description  String?
  imageUrl     String?
  prepTimeMins Int?
  cookTimeMins Int?
  servings     Int      @default(1)
  calories     Int?
  proteinG     Float?
  carbsG       Float?
  fatG         Float?
  ingredients  Json     // [{name, amount, unit}]
  instructions String?
  tags         String[] // ["high-protein", "quick", "vegetarian"]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  weeklyMealEntries WeeklyMealEntry[]
  dailyMeals        DailyMeal[]

  @@map("recipes")
}

model WeeklyMealEntry {
  id             String         @id @default(cuid())
  weeklyPlanId   String
  weeklyPlan     WeeklyMealPlan @relation(fields: [weeklyPlanId], references: [id], onDelete: Cascade)
  dayOfWeek      DayOfWeek
  mealType       MealType
  recipeId       String?
  recipe         Recipe?        @relation(fields: [recipeId], references: [id])
  customMealName String?        // si no hay receta asociada
  notes          String?

  @@map("weekly_meal_entries")
}

model DailyIntake {
  id             String        @id @default(cuid())
  nutritionPlanId String
  nutritionPlan  NutritionPlan @relation(fields: [nutritionPlanId], references: [id])
  date           DateTime      @db.Date
  totalCalories  Int?
  totalProteinG  Float?
  totalCarbsG    Float?
  totalFatG      Float?
  waterMl        Int?
  notes          String?
  createdAt      DateTime      @default(now())

  meals          DailyMeal[]

  @@unique([nutritionPlanId, date])
  @@map("daily_intakes")
}

model DailyMeal {
  id           String      @id @default(cuid())
  dailyIntakeId String
  dailyIntake  DailyIntake @relation(fields: [dailyIntakeId], references: [id], onDelete: Cascade)
  mealType     MealType
  recipeId     String?
  recipe       Recipe?     @relation(fields: [recipeId], references: [id])
  customName   String?
  calories     Int?
  proteinG     Float?
  carbsG       Float?
  fatG         Float?
  servings     Float       @default(1)
  loggedAt     DateTime    @default(now())

  @@map("daily_meals")
}

// ─────────────────────────────────────────
// PROGRESS LOGS
// ─────────────────────────────────────────

model ProgressLog {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])
  date        DateTime @db.Date
  weightKg    Float?
  bodyFatPct  Float?
  muscleMassKg Float?

  // Medidas corporales (cm)
  chestCm     Float?
  waistCm     Float?
  hipsCm      Float?
  leftArmCm   Float?
  rightArmCm  Float?
  leftLegCm   Float?
  rightLegCm  Float?

  // Fuerza (para seguimiento de progresión)
  benchPressKg Float?
  squatKg      Float?
  deadliftKg   Float?

  photoUrls   String[]
  notes       String?
  createdAt   DateTime @default(now())

  @@unique([clientId, date])
  @@map("progress_logs")
}

// ─────────────────────────────────────────
// TRAINER AVAILABILITY / CALENDAR
// ─────────────────────────────────────────

model TrainerAvailability {
  id              String         @id @default(cuid())
  trainerProfileId String
  trainerProfile  TrainerProfile @relation(fields: [trainerProfileId], references: [id], onDelete: Cascade)
  dayOfWeek       DayOfWeek
  startTime       String         // "09:00"
  endTime         String         // "18:00"
  isAvailable     Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([trainerProfileId, dayOfWeek])
  @@map("trainer_availability")
}

// ─────────────────────────────────────────
// COMMUNICATION (Messaging)
// ─────────────────────────────────────────

model Conversation {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation("ConversationClient", fields: [clientId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages  Message[]

  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("MessageSender", fields: [senderId], references: [id])
  content        String
  type           MessageType  @default(TEXT)
  fileUrl        String?
  readAt         DateTime?
  createdAt      DateTime     @default(now())

  @@map("messages")
}
